@model IEnumerable<Projecttest.Models.StudySession>

@{
    ViewData["Title"] = "Histórico de Estudos";
    
    string GetBadgeColor(string badgeName)
    {
        return badgeName switch
        {
            "Foco" => "bg-primary",           // Azul
            "Estudo" => "bg-success",         // Verde
            "Exercícios" => "bg-warning text-dark", // Amarelo
            "Videoaulas" => "bg-danger",      // Vermelho
            "Pesquisas" => "bg-info text-dark",// Ciano
            "Documentações" => "bg-secondary",// Cinza
            _ => "bg-primary"
        };
    }
}

<style>
    .history-card {
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease;
        animation: fadeInUp 0.4s ease-out forwards;
        opacity: 0;
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }
    
    .history-card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 12px 20px rgba(0,0,0,0.15) !important;
    }
    
    .history-card .card-body {
        padding: 1.5rem;
    }

    [data-theme='dark'] .history-card {
        box-shadow: 0 4px 6px rgba(0,0,0,0.3);
        border: 1px solid rgba(255,255,255,0.05);
    }

    [data-theme='dark'] .history-card:hover {
        box-shadow: 0 12px 20px rgba(0,0,0,0.5) !important;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .search-btn {
        background-color: var(--bs-primary) !important;
        color: white !important;
        border-color: var(--bs-primary) !important;
    }
    .search-btn:hover {
        background-color: #0b5ed7 !important;
        border-color: #0a58ca !important;
    }
</style>

<div class="container mt-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 gap-3">
        <h2 class="mb-0 fw-bold">Histórico de Estudos</h2>
        <a asp-action="Index" class="btn btn-primary px-4 rounded-pill shadow-sm">Voltar ao cronômetro</a>
    </div>

    <div class="mb-5 position-relative mx-auto" style="max-width: 600px;">
        <form asp-action="History" method="get" class="d-flex w-100">
            <div class="input-group shadow-sm border-0 rounded-pill overflow-hidden">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-0 px-4 py-3" placeholder="Buscar matéria ou assunto..." aria-label="Pesquisar">
                <button type="submit" class="btn px-4 search-btn">
                    <i class="bi bi-search me-1"></i> Buscar
                </button>
            </div>
            @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
            {
                <a asp-action="History" class="position-absolute end-0 top-50 translate-middle-y text-danger me-2" style="right: -40px !important; text-decoration: none;" title="Limpar filtro">
                    <i class="bi bi-x-circle-fill fs-4"></i>
                </a>
            }
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info rounded-3 border-0 shadow-sm text-center py-4 mt-3">
            <h5 class="mb-0">Nenhuma sessão de estudo encontrada.</h5>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var s in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 history-card">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold mb-1 text-primary">@(string.IsNullOrWhiteSpace(s.Subject) ? "Sessão de estudo" : s.Subject)</h5>
                            <h6 class="card-subtitle mb-3 text-muted small">
                                <i class="bi bi-calendar-event me-1"></i>@s.StartTime.ToShortDateString()
                            </h6>
                            
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-secondary small">Início:</span>
                                <strong>@s.StartTime.ToShortTimeString()</strong>
                            </div>
                            <div class="d-flex justify-content-between mb-3">
                                <span class="text-secondary small">Fim:</span>
                                <strong>@s.EndTime.ToShortTimeString()</strong>
                            </div>
                            
                            @if(s.TargetMinutes.HasValue && s.TargetMinutes > 0)
                            {
                                <div class="d-flex justify-content-between mb-3">
                                    <span class="text-secondary small">Meta:</span>
                                    <strong>@s.TargetMinutes min</strong>
                                </div>
                            }
                            
                            <div class="mt-auto d-flex align-items-center justify-content-between border-top pt-3">
                                <div class="d-flex flex-column">
                                    <span class="text-secondary small">Duração</span>
                                    <span class="fs-5 fw-bold">@s.DurationMinutes <span class="fs-6 fw-normal">min</span></span>
                                </div>
                                <span class="badge @GetBadgeColor(s.Badge ?? "Foco") rounded-pill px-3 py-2">
                                    @(s.Badge ?? "Foco")
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
