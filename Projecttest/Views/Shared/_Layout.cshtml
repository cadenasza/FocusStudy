<!DOCTYPE html>
<html lang="pt-br" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FocusStudy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Projecttest.styles.css" asp-append-version="true" />
    <!-- Adicionando Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root[data-theme='light'] {
            --bg-color: #f5f5f7;
            --card-bg: #ffffff;
            --text-color: #212529;
            --nav-bg: #ffffff;
            --input-bg: #f8f9fa;
            --input-text: #212529;
            --ring-bg: #e9ecef;
            --ring-progress: #198754; /* Verde sucesso de destaque em temas claros */
        }
        :root[data-theme='dark'] {
            --bg-color: #0b0c10;
            --card-bg: #1f2326;
            --text-color: #e2e8f0;
            --nav-bg: #15171a;
            --input-bg: #2a2f35;
            --input-text: #e2e8f0;
            --ring-bg: #2a2f35;
            --ring-progress: #20c997; /* Verde neon super legível em temas escuros */
        }
        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            transition: background-color 0.3s ease, color 0.3s ease;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        .main-content {
            flex: 1;
        }
        .card {
            background-color: var(--card-bg);
            transition: background-color 0.3s ease;
            border: 1px solid rgba(255, 255, 255, 0.05); /* Suave divisão */
        }
        .navbar-custom {
            background-color: var(--nav-bg) !important;
            transition: background-color 0.3s ease;
            border-bottom: 2px solid #198754 !important; /* Linha sutil de verde no topo */
        }
        .navbar-custom * {
            color: var(--text-color) !important;
        }
        .text-muted {
            color: #94a3b8 !important; /* Mais legibilidade para textos secundários no escuro */
        }
        
        /* Ajuste de inputs pra se adaptarem perfeitamente no escuro */
        .form-control, .form-select {
            background-color: var(--input-bg) !important;
            color: var(--input-text) !important;
        }
        .form-control::placeholder {
            color: #64748b;
        }
        
        /* Cores consistentes no foco */
        .form-control:focus, .form-select:focus {
            box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25) !important;
            border-color: #198754 !important;
        }

        /* Específico do relógio (Ring) */
        svg circle#progressCircle {
            stroke: var(--ring-progress);
        }
        svg circle:first-child {
            stroke: var(--ring-bg);
        }

        /* Redifinir text-primary e afins para algo mais brilhante e visível no escuro */
        [data-theme='dark'] .text-primary {
            color: #5eead4 !important; /* Ciano claro, muito legível contra fundo escuro */
        }
        [data-theme='dark'] .btn-outline-primary {
            color: #20c997;
            border-color: #20c997;
        }
        [data-theme='dark'] .btn-outline-primary:hover {
            background-color: #20c997;
            color: #0b0c10;
        }

    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-custom shadow-sm mb-4">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-stopwatch text-success me-1"></i>FocusStudy
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Cronômetro</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="History">Histórico</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item me-3">
                            <button id="themeToggle" class="btn btn-outline-success btn-sm rounded-circle px-2">🌙</button>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">Cadastro</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Logout">Sair</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container main-content">
        <main role="main" class="pb-5 mb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top border-secondary footer mt-auto">
        <div class="container text-center" style="color: var(--text-color); opacity: 0.7;">
            &copy; @DateTime.Now.Year - FocusStudy
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            const root = document.documentElement;
            // Padronizando darkMode como initial
            const savedTheme = localStorage.getItem('theme') || 'dark';
            root.setAttribute('data-theme', savedTheme);

            const btn = document.getElementById('themeToggle');
            if (btn) {
                btn.textContent = savedTheme === 'dark' ? '☀️' : '🌙';
                btn.addEventListener('click', function () {
                    const current = root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
                    const next = current === 'dark' ? 'light' : 'dark';
                    root.setAttribute('data-theme', next);
                    localStorage.setItem('theme', next);
                    btn.textContent = next === 'dark' ? '☀️' : '🌙';
                });
            }
        })();
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
